generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./winrak.db"
}

// ─── MODELS ───────────────────────────────────────────────────
model User {
  id                String    @id @default(uuid())
  phone             String    @unique
  fullName          String?
  email             String?   @unique
  avatarUrl         String?
  role              String    @default("PASSENGER")
  winPoints         Int       @default(0)
  preferredLanguage String    @default("ar")
  isVerified        Boolean   @default(false)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  driver            Driver?
  ridesAsPassenger  Ride[]          @relation("PassengerRides")
  ratingsGiven      Rating[]        @relation("ReviewerRatings")
  ratingsReceived   Rating[]        @relation("RevieweeRatings")
  notifications     Notification[]
  winPointsHistory  WinPointsLog[]
  otpCodes          OtpCode[]
  emergencyContacts EmergencyContact[]

  @@map("users")
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String?
  phone     String
  code      String
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])

  @@map("otp_codes")
}

model EmergencyContact {
  id        String   @id @default(uuid())
  userId    String
  name      String
  phone     String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@map("emergency_contacts")
}

model Driver {
  id             String    @id @default(uuid())
  userId         String    @unique
  status         String    @default("PENDING")
  rating         Float     @default(5.0)
  totalTrips     Int       @default(0)
  totalEarnings  Float     @default(0)
  isOnline       Boolean   @default(false)
  currentLat     Float?
  currentLng     Float?
  currentHeading Float?
  lastSeenAt     DateTime?
  fcmToken       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user      User             @relation(fields: [userId], references: [id])
  vehicles  Vehicle[]
  contracts DriverContract[]
  ridesAsDriver Ride[]       @relation("DriverRides")
  incidents Incident[]
  earnings  Earning[]
  documents DriverDocument[]

  @@map("drivers")
}

model DriverDocument {
  id           String    @id @default(uuid())
  driverId     String
  docType      String
  fileUrl      String
  isVerified   Boolean   @default(false)
  rejectedNote String?
  uploadedAt   DateTime  @default(now())
  verifiedAt   DateTime?

  driver       Driver    @relation(fields: [driverId], references: [id])

  @@map("driver_documents")
}

model Vehicle {
  id          String   @id @default(uuid())
  driverId    String
  brand       String
  model       String
  year        Int
  color       String
  plateNumber String   @unique
  vehicleType String
  isVerified  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  driver      Driver   @relation(fields: [driverId], references: [id])
  rides       Ride[]

  @@map("vehicles")
}

model DriverContract {
  id                  String    @id @default(uuid())
  driverId            String
  contractType        String    @default("STANDARD")
  profitWinrakPercent Float
  profitDriverPercent Float
  lossWinrakPercent   Float
  lossDriverPercent   Float
  monthlyLossCap      Float
  signedAt            DateTime?
  validUntil          DateTime?
  digitalSignature    String?
  termsHash           String?
  termsVersion        String    @default("v1.0")
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  driver    Driver     @relation(fields: [driverId], references: [id])
  incidents Incident[]

  @@map("driver_contracts")
}

model Ride {
  id               String    @id @default(uuid())
  passengerId      String
  driverId         String?
  vehicleId        String?
  status           String    @default("REQUESTED")
  serviceType      String    @default("GO")
  pickupLat        Float
  pickupLng        Float
  pickupAddress    String
  dropoffLat       Float
  dropoffLng       Float
  dropoffAddress   String
  distanceKm       Float?
  durationMinutes  Int?
  baseFare         Float?
  totalFare        Float?
  paymentMethod    String    @default("CASH")
  paymentStatus    String    @default("PENDING")
  cancelledBy      String?
  cancellationNote String?
  requestedAt      DateTime  @default(now())
  acceptedAt       DateTime?
  arrivedAt        DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?

  passenger     User          @relation("PassengerRides", fields: [passengerId], references: [id])
  driver        Driver?       @relation("DriverRides", fields: [driverId], references: [id])
  vehicle       Vehicle?      @relation(fields: [vehicleId], references: [id])
  ratings       Rating[]
  incident      Incident?
  payment       Payment?
  chatMessages  ChatMessage[]
  locationHistory RideLocationLog[]

  @@map("rides")
}

model RideLocationLog {
  id       String   @id @default(uuid())
  rideId   String
  lat      Float
  lng      Float
  heading  Float?
  speed    Float?
  loggedAt DateTime @default(now())

  ride     Ride     @relation(fields: [rideId], references: [id])

  @@map("ride_location_logs")
}

model ChatMessage {
  id       String   @id @default(uuid())
  rideId   String
  senderId String
  message  String
  isRead   Boolean  @default(false)
  sentAt   DateTime @default(now())

  ride     Ride     @relation(fields: [rideId], references: [id])

  @@map("chat_messages")
}

model Payment {
  id              String    @id @default(uuid())
  rideId          String    @unique
  amount          Float
  method          String
  status          String    @default("PENDING")
  stripePaymentId String?
  receiptUrl      String?
  winrakCut       Float?
  driverCut       Float?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  ride            Ride      @relation(fields: [rideId], references: [id])

  @@map("payments")
}

model Earning {
  id          String   @id @default(uuid())
  driverId    String
  rideId      String?
  amount      Float
  type        String
  description String?
  earnedAt    DateTime @default(now())

  driver      Driver   @relation(fields: [driverId], references: [id])

  @@map("earnings")
}

model Incident {
  id              String    @id @default(uuid())
  rideId          String    @unique
  driverId        String
  contractId      String?
  incidentType    String
  description     String
  totalLossAmount Float?
  winrakCovers    Float?
  driverCovers    Float?
  status          String    @default("PENDING")
  evidenceUrls    String    @default("[]")
  adminNote       String?
  reportedAt      DateTime  @default(now())
  resolvedAt      DateTime?

  ride     Ride            @relation(fields: [rideId], references: [id])
  driver   Driver          @relation(fields: [driverId], references: [id])
  contract DriverContract? @relation(fields: [contractId], references: [id])

  @@map("incidents")
}

model Rating {
  id                   String   @id @default(uuid())
  rideId               String
  reviewerId           String
  revieweeId           String
  overallScore         Float
  cleanlinessScore     Int?
  professionalismScore Int?
  safetyScore          Int?
  punctualityScore     Int?
  comment              String?
  voiceNoteUrl         String?
  createdAt            DateTime @default(now())

  ride     Ride @relation(fields: [rideId], references: [id])
  reviewer User @relation("ReviewerRatings", fields: [reviewerId], references: [id])
  reviewee User @relation("RevieweeRatings", fields: [revieweeId], references: [id])

  @@unique([rideId, reviewerId])
  @@map("ratings")
}

model Notification {
  id      String   @id @default(uuid())
  userId  String
  type    String
  title   String
  body    String
  data    String?
  isRead  Boolean  @default(false)
  sentAt  DateTime @default(now())
  readAt  DateTime?

  user    User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model WinPointsLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  points      Int
  description String?
  rideId      String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@map("win_points_logs")
}

model PricingConfig {
  id              String   @id @default(uuid())
  vehicleType     String   @unique
  baseFare        Float
  pricePerKm      Float
  waitingPerMin   Float
  surgeMultiplier Float    @default(1.0)
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  @@map("pricing_configs")
}

model SosAlert {
  id          String    @id @default(uuid())
  userId      String
  rideId      String?
  lat         Float
  lng         Float
  isResolved  Boolean   @default(false)
  triggeredAt DateTime  @default(now())
  resolvedAt  DateTime?

  @@map("sos_alerts")
}
