# ═══════════════════════════════════════════════════════
#  WinRak — Variables d'environnement
#  1. Copiez ce fichier vers .env.local
#  2. Remplacez les valeurs par celles de votre projet Supabase
#     (Dashboard Supabase → Settings → API)
# ═══════════════════════════════════════════════════════

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=VOTRE_ANON_KEY

# Dashboard Web (même valeurs, sans préfixe EXPO_PUBLIC)
SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=VOTRE_ANON_KEY
SUPABASE_SERVICE_KEY=VOTRE_SERVICE_ROLE_KEY
