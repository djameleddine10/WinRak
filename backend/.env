# Database — SQLite (no installation needed!)
DATABASE_URL="file:./prisma/winrak.db"

# Redis — optional, falls back to in-memory automatically
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="winrak-jwt-super-secret-2025"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# App
PORT=3000
NODE_ENV="development"
CLIENT_URL="http://localhost:5173"

# OTP — In development mode, OTP is printed to console (no Twilio needed!)
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Twilio (optional in dev)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Google Maps (optional — uses Haversine fallback if not set)
GOOGLE_MAPS_API_KEY=""

# Stripe (optional)
STRIPE_SECRET_KEY=""

# Firebase (optional)
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""
